{
  "name": "loga3",
  "version": "1.0.0",
  "main": "src/loga3-automation.js",
  "bin": {
    "loga3": "bin/loga3.js"
  },
  "scripts": {
    "gui": "node src/loga3-gui-server.js",
    "gui:stop": "sh -c 'pids=$(lsof -ti :3847 2>/dev/null); [ -n \"$pids\" ] && kill -TERM $pids 2>/dev/null; sleep 1; pids=$(lsof -ti :3847 2>/dev/null); [ -n \"$pids\" ] && kill -9 $pids 2>/dev/null; pkill -f \"loga3-complete.js\" 2>/dev/null; echo GUI gestoppt'",
    "gui:restart": "npm run gui:stop; sleep 1; npm run gui",
    "fetch": "node bin/loga3.js fetch",
    "download": "node src/loga3-complete.js --once",
    "download:last1": "node src/loga3-complete.js --once --last 1",
    "download:last3": "node src/loga3-complete.js --once --last 3",
    "download:last6": "node src/loga3-complete.js --once --last 6",
    "download:next1": "node src/loga3-complete.js --once --next 1",
    "download:next3": "node src/loga3-complete.js --once --next 3",
    "download:next6": "node src/loga3-complete.js --once --next 6",
    "debug:content": "node test/debug-content-update.js --last 3",
    "test:download": "node test/test-download-save.js",
    "test:desktop-stage": "node scripts/build-desktop.js --stage-only",
    "test": "npm run test:download && npm run test:desktop-stage",
    "package:linux": "node scripts/build-desktop.js --target linux",
    "package:win": "node scripts/build-desktop.js --target win32",
    "package:desktop": "node scripts/build-desktop.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "dotenv": "^17.2.2",
    "playwright": "^1.58.1"
  }
}
