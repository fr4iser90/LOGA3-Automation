# Copy to .env only if you prefer env vars over the GUI (optional):
#   cp .env.example .env
#
# End users: open the web UI and save username/password there.
# No .env required.

# LOGA3_USERNAME=your_username
# LOGA3_PASSWORD=your_password

# Optional
# LOGA3_GUI_PORT=3847
# LOGA3_GUI_HOST=127.0.0.1
# LOGA3_HEADLESS=1
# LOGA3_OPEN_BROWSER=1
# LOGA3_LOCALE=de
# LOGA3_DEBUG=1
# LOGA3_DOWNLOADS_DIR=
# LOGA3_LOGS_DIR=
# LOGA3_CONVERTER_URL=http://127.0.0.1:3847/#convert
